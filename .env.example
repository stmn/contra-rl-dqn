# Paths
ROM_PATH=./roms/contra.nes

# Training
DEVICE=cpu          # cpu, cuda, mps (Apple Silicon)
TOTAL_TIMESTEPS=100000000

# Web dashboard
WEB_PORT=41918

# Rewards
DEATH_PENALTY=-500.0
PROGRESS_SCALE=1.0

# Feature flags
HYBRID_OBSERVATION=true     # CNN + 28 RAM features
PRIORITISED_REPLAY=true     # PER: surprise-weighted sampling
OVERLAY_SPRITES=true        # Shape markers on game frames
DUELING_DQN=true            # Separate V(state) + A(action) streams
NOISY_NETS=true             # Noisy linear layers (no epsilon-greedy)
N_STEP_RETURNS=3            # N-step returns (1 = standard)
HUBER_LOSS=true             # Smooth L1 loss (robust to outliers)
GRADIENT_CLIP=10.0          # Max gradient norm (0 = disabled)
